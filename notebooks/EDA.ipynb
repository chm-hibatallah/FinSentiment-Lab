"""
notebooks/eda.py
-----------------
Exploratory Data Analysis for FinSentiment Lab.

Run this AFTER both pipelines have produced data:
  - data/processed/raw_aligned_*.parquet      (Module 1)
  - data/processed/enriched_*.parquet         (Module 2)

Usage
-----
    python notebooks/eda.py                      # uses latest enriched parquet
    python notebooks/eda.py --input path/to.parquet
    python notebooks/eda.py --save               # saves all plots to reports/eda/

What this script answers
------------------------
  Q1.  How is sentiment distributed? Is FinBERT biased toward neutral?
  Q2.  How many trading days have news coverage vs. silent days?
  Q3.  Is there a visual relationship between sentiment and next-day return?
  Q4.  Do sentiment and price move together over time?
  Q5.  What does the lag-N correlation look like? (N = 1…5 days)
  Q6.  Are AAPL / TSLA / MSFT behaving differently?
  Q7.  How often does sentiment flip sign? (momentum distribution)
  Q8.  Are there outlier days worth investigating?
  Q9.  What is the label balance per ticker?
  Q10. Rolling 30-day correlation: does the relationship change over time?
"""

from __future__ import annotations

import argparse
import glob
import os
import sys
import warnings
from typing import Optional

import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
import matplotlib.ticker as mticker
import numpy as np
import pandas as pd
import seaborn as sns
from scipy import stats

warnings.filterwarnings("ignore")

# ---------------------------------------------------------------------------
# Style — dark terminal-grade theme, financial data aesthetic
# ---------------------------------------------------------------------------
plt.rcParams.update({
    "figure.facecolor":  "#0d1117",
    "axes.facecolor":    "#161b22",
    "axes.edgecolor":    "#30363d",
    "axes.labelcolor":   "#c9d1d9",
    "axes.titlecolor":   "#f0f6fc",
    "axes.titlesize":    13,
    "axes.labelsize":    11,
    "axes.grid":         True,
    "grid.color":        "#21262d",
    "grid.linewidth":    0.8,
    "xtick.color":       "#8b949e",
    "ytick.color":       "#8b949e",
    "text.color":        "#c9d1d9",
    "legend.facecolor":  "#161b22",
    "legend.edgecolor":  "#30363d",
    "legend.fontsize":   9,
    "font.family":       "monospace",
    "figure.titlesize":  15,
    "figure.titleweight": "bold",
})

# Ticker colour palette
TICKER_COLORS = {
    "AAPL":  "#58a6ff",   # blue
    "TSLA":  "#f78166",   # red-orange
    "MSFT":  "#56d364",   # green
}
DEFAULT_COLOR = "#a5d6ff"

SENTIMENT_COLORS = {
    "bullish": "#56d364",
    "neutral": "#8b949e",
    "bearish": "#f78166",
}


# ===========================================================================
# Data loading
# ===========================================================================

def load_data(input_path: Optional[str] = None) -> pd.DataFrame:
    """Load the most recent enriched parquet, or a specific path."""
    if input_path and os.path.exists(input_path):
        path = input_path
    else:
        pattern = os.path.join("data", "processed", "enriched_*.parquet")
        files   = sorted(glob.glob(pattern))
        if not files:
            # Fallback: try raw_aligned for a partial analysis
            pattern = os.path.join("data", "processed", "raw_aligned_*.parquet")
            files   = sorted(glob.glob(pattern))
        if not files:
            print("ERROR: No parquet files found in data/processed/")
            print("Run data_collection.pipeline and sentiment_engine.pipeline first.")
            sys.exit(1)
        path = files[-1]

    print(f"Loading: {path}")
    df = pd.read_parquet(path)
    df["date"] = pd.to_datetime(df["date"])
    print(f"Shape  : {df.shape}  |  Tickers: {df['ticker'].unique().tolist()}")
    print(f"Range  : {df['date'].min().date()} → {df['date'].max().date()}\n")
    return df


def _ticker_color(ticker: str) -> str:
    return TICKER_COLORS.get(ticker, DEFAULT_COLOR)


def _save_or_show(fig, name: str, save_dir: Optional[str]):
    if save_dir:
        os.makedirs(save_dir, exist_ok=True)
        path = os.path.join(save_dir, f"{name}.png")
        fig.savefig(path, dpi=150, bbox_inches="tight", facecolor=fig.get_facecolor())
        print(f"  Saved → {path}")
    else:
        plt.show()
    plt.close(fig)


# ===========================================================================
# EDA PLOTS
# ===========================================================================

# ---------------------------------------------------------------------------
# Q1 + Q9 — Sentiment score distribution & label balance
# ---------------------------------------------------------------------------

def plot_sentiment_distribution(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    Two panels:
      Left  — KDE of mean_score per ticker (shows FinBERT bias)
      Right — Stacked bar: label proportions per ticker
    """
    has_sentiment = "mean_score" in df.columns and df["mean_score"].notna().any()
    if not has_sentiment:
        print("  [SKIP] No sentiment scores found — run Module 2 first.")
        return

    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    fig.suptitle("Q1 + Q9 · Sentiment Distribution & Label Balance", y=1.02)

    # Left: KDE per ticker
    ax = axes[0]
    scored = df[df["mean_score"].notna() & (df["article_count"] > 0)]
    for ticker, group in scored.groupby("ticker"):
        color = _ticker_color(ticker)
        group["mean_score"].plot.kde(ax=ax, label=ticker, color=color, linewidth=2)
    ax.axvline(0, color="#f0f6fc", linewidth=0.8, linestyle="--", alpha=0.5)
    ax.axvline(0.15,  color=SENTIMENT_COLORS["bullish"], linewidth=0.6, linestyle=":", alpha=0.6)
    ax.axvline(-0.15, color=SENTIMENT_COLORS["bearish"], linewidth=0.6, linestyle=":", alpha=0.6)
    ax.set_title("Score Distribution (KDE)")
    ax.set_xlabel("Daily Mean Sentiment Score")
    ax.set_ylabel("Density")
    ax.legend()

    # Annotation: check for neutral bias
    for ticker, group in scored.groupby("ticker"):
        pct_neutral = (group["dominant_label"] == "neutral").mean() * 100
        if pct_neutral > 60:
            ax.text(0.02, 0.95, f"⚠ {ticker}: {pct_neutral:.0f}% neutral days",
                    transform=ax.transAxes, fontsize=8, color="#f0b429",
                    verticalalignment="top")

    # Right: stacked bar
    ax2 = axes[1]
    if "dominant_label" in df.columns:
        label_counts = (
            df[df["article_count"] > 0]
            .groupby(["ticker", "dominant_label"])
            .size()
            .unstack(fill_value=0)
        )
        # Normalise to proportions
        label_pct = label_counts.div(label_counts.sum(axis=1), axis=0) * 100
        bottom = np.zeros(len(label_pct))
        for label in ["bearish", "neutral", "bullish"]:
            if label in label_pct.columns:
                vals = label_pct[label].values
                ax2.bar(label_pct.index, vals, bottom=bottom,
                        color=SENTIMENT_COLORS[label], label=label, width=0.5)
                # Value labels inside bars
                for i, (v, b) in enumerate(zip(vals, bottom)):
                    if v > 5:
                        ax2.text(i, b + v/2, f"{v:.0f}%", ha="center", va="center",
                                 fontsize=9, color="white", fontweight="bold")
                bottom += vals
        ax2.set_title("Label Balance per Ticker (days with news)")
        ax2.set_ylabel("% of Days")
        ax2.set_ylim(0, 105)
        ax2.legend(loc="upper right")

    fig.tight_layout()
    _save_or_show(fig, "01_sentiment_distribution", save_dir)


# ---------------------------------------------------------------------------
# Q2 — News coverage
# ---------------------------------------------------------------------------

def plot_news_coverage(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    Two panels:
      Left  — Article count over time per ticker
      Right — Coverage rate: % of trading days with ≥1 article
    """
    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    fig.suptitle("Q2 · News Coverage Analysis", y=1.02)

    # Left: article count time-series
    ax = axes[0]
    for ticker, group in df.groupby("ticker"):
        g = group.set_index("date").sort_index()
        ax.fill_between(g.index, g["article_count"],
                        alpha=0.3, color=_ticker_color(ticker))
        ax.plot(g.index, g["article_count"],
                color=_ticker_color(ticker), linewidth=1.2, label=ticker)
    ax.set_title("Daily Article Count")
    ax.set_xlabel("Date")
    ax.set_ylabel("Articles / Day")
    ax.legend()

    # Right: coverage rate bar
    ax2 = axes[1]
    coverage = (
        df.groupby("ticker")
        .apply(lambda g: (g["article_count"] > 0).mean() * 100)
        .reset_index(name="coverage_pct")
    )
    bars = ax2.barh(coverage["ticker"], coverage["coverage_pct"],
                    color=[_ticker_color(t) for t in coverage["ticker"]], height=0.5)
    for bar, val in zip(bars, coverage["coverage_pct"]):
        ax2.text(val + 1, bar.get_y() + bar.get_height()/2,
                 f"{val:.1f}%", va="center", fontsize=10)
    ax2.set_title("Trading Days with ≥1 Article")
    ax2.set_xlabel("Coverage Rate (%)")
    ax2.set_xlim(0, 110)
    ax2.axvline(50, color="#f0b429", linewidth=0.8, linestyle="--", alpha=0.6)

    fig.tight_layout()
    _save_or_show(fig, "02_news_coverage", save_dir)


# ---------------------------------------------------------------------------
# Q3 — Sentiment vs. next-day return scatter
# ---------------------------------------------------------------------------

def plot_sentiment_vs_return(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    Scatter: daily mean_score vs. next-day daily_return.
    Adds a linear regression line and Pearson r annotation.
    The key plot for 'does negative news predict price drops?'
    """
    if "mean_score" not in df.columns:
        print("  [SKIP] No sentiment scores.")
        return

    # Create next-day return column
    df = df.copy().sort_values(["ticker", "date"])
    df["next_day_return"] = df.groupby("ticker")["daily_return"].shift(-1)

    scored = df[df["mean_score"].notna() & df["next_day_return"].notna() & (df["article_count"] > 0)]
    if scored.empty:
        print("  [SKIP] Not enough scored + return data for scatter.")
        return

    tickers = scored["ticker"].unique()
    ncols   = min(3, len(tickers))
    fig, axes = plt.subplots(1, ncols, figsize=(5 * ncols, 5), sharey=True)
    if ncols == 1:
        axes = [axes]
    fig.suptitle("Q3 · Sentiment Score → Next-Day Return", y=1.02)

    for ax, ticker in zip(axes, tickers):
        g = scored[scored["ticker"] == ticker]
        x = g["mean_score"].values
        y = g["next_day_return"].values * 100   # convert to %

        color = _ticker_color(ticker)
        ax.scatter(x, y, alpha=0.5, s=20, color=color, edgecolors="none")

        # Regression line
        if len(x) > 5:
            slope, intercept, r, p, _ = stats.linregress(x, y)
            x_line = np.linspace(x.min(), x.max(), 100)
            ax.plot(x_line, slope * x_line + intercept,
                    color="#f0f6fc", linewidth=1.5, linestyle="--")
            sig = "✓" if p < 0.05 else "✗"
            ax.text(0.05, 0.93,
                    f"r = {r:.3f}  p = {p:.3f} {sig}",
                    transform=ax.transAxes, fontsize=9,
                    color="#f0f6fc", bbox=dict(facecolor="#21262d", alpha=0.8, pad=3))

        ax.axhline(0, color="#8b949e", linewidth=0.6)
        ax.axvline(0, color="#8b949e", linewidth=0.6)
        ax.set_title(ticker, color=color, fontsize=13)
        ax.set_xlabel("Daily Sentiment Score")
    axes[0].set_ylabel("Next-Day Return (%)")

    fig.tight_layout()
    _save_or_show(fig, "03_sentiment_vs_return", save_dir)


# ---------------------------------------------------------------------------
# Q4 — Dual-axis time series: sentiment + price
# ---------------------------------------------------------------------------

def plot_sentiment_and_price(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    For each ticker: dual-axis chart.
      Left axis  — normalised close price
      Right axis — daily mean sentiment score (bar chart)
    """
    if "mean_score" not in df.columns:
        print("  [SKIP] No sentiment scores.")
        return

    tickers = df["ticker"].unique()
    fig, axes = plt.subplots(len(tickers), 1, figsize=(14, 4 * len(tickers)))
    if len(tickers) == 1:
        axes = [axes]
    fig.suptitle("Q4 · Sentiment Score vs. Price Over Time", y=1.01)

    for ax, ticker in zip(axes, tickers):
        g = df[df["ticker"] == ticker].set_index("date").sort_index()
        color = _ticker_color(ticker)

        # Normalise price to 100
        price_norm = g["close"] / g["close"].iloc[0] * 100

        ax.plot(price_norm.index, price_norm.values, color=color,
                linewidth=1.5, label=f"{ticker} Price (norm.)")
        ax.set_ylabel("Price (base=100)", color=color)
        ax.tick_params(axis="y", labelcolor=color)

        # Right axis: sentiment bars
        ax2 = ax.twinx()
        ax2.set_facecolor("#161b22")
        if "mean_score" in g.columns:
            scored_days = g[g["mean_score"].notna() & (g.get("article_count", 0) > 0)]
            bar_colors  = [
                SENTIMENT_COLORS.get(str(lbl), "#8b949e")
                for lbl in scored_days.get("dominant_label", ["neutral"] * len(scored_days))
            ]
            ax2.bar(scored_days.index, scored_days["mean_score"],
                    color=bar_colors, alpha=0.55, width=1.0)
            ax2.axhline(0,     color="#8b949e", linewidth=0.5)
            ax2.axhline(0.15,  color=SENTIMENT_COLORS["bullish"], linewidth=0.4, linestyle=":")
            ax2.axhline(-0.15, color=SENTIMENT_COLORS["bearish"], linewidth=0.4, linestyle=":")
        ax2.set_ylabel("Sentiment Score", color="#8b949e")
        ax2.tick_params(axis="y", labelcolor="#8b949e")

        ax.set_title(ticker, color=color)
        ax.legend(loc="upper left")

    fig.tight_layout()
    _save_or_show(fig, "04_sentiment_and_price", save_dir)


# ---------------------------------------------------------------------------
# Q5 — Lag correlation: does sentiment at t-N predict return at t?
# ---------------------------------------------------------------------------

def plot_lag_correlations(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    Bar chart: Pearson r between sentiment(t-N) and daily_return(t) for N=0…5.
    The lag with the highest |r| is the most predictive window.
    """
    if "mean_score" not in df.columns:
        print("  [SKIP] No sentiment scores for lag analysis.")
        return

    lags    = list(range(0, 6))
    tickers = df["ticker"].unique()
    fig, axes = plt.subplots(1, len(tickers), figsize=(5 * len(tickers), 5), sharey=True)
    if len(tickers) == 1:
        axes = [axes]
    fig.suptitle("Q5 · Lag Correlation: Sentiment(t-N) → Return(t)", y=1.02)

    for ax, ticker in zip(axes, tickers):
        g = df[df["ticker"] == ticker].sort_values("date").copy()
        g = g[g["mean_score"].notna()]

        rs, ps = [], []
        for lag in lags:
            g[f"sentiment_lag{lag}"] = g["mean_score"].shift(lag)
            pair = g[["daily_return", f"sentiment_lag{lag}"]].dropna()
            if len(pair) > 10:
                r, p = stats.pearsonr(pair[f"sentiment_lag{lag}"], pair["daily_return"])
            else:
                r, p = 0.0, 1.0
            rs.append(r)
            ps.append(p)

        colors = [
            SENTIMENT_COLORS["bullish"] if r > 0 else SENTIMENT_COLORS["bearish"]
            for r in rs
        ]
        bars = ax.bar([f"t-{l}" for l in lags], rs, color=colors, width=0.6)

        # Significance markers
        for bar, r, p in zip(bars, rs, ps):
            marker = "**" if p < 0.01 else ("*" if p < 0.05 else "")
            if marker:
                ax.text(bar.get_x() + bar.get_width()/2,
                        r + (0.003 if r >= 0 else -0.006),
                        marker, ha="center", fontsize=11,
                        color=_ticker_color(ticker))

        ax.axhline(0, color="#8b949e", linewidth=0.6)
        ax.set_title(ticker, color=_ticker_color(ticker), fontsize=13)
        ax.set_xlabel("Sentiment Lag")
        ax.set_ylim(-0.3, 0.3)

    axes[0].set_ylabel("Pearson r")
    fig.text(0.5, -0.02,
             "* p<0.05  ** p<0.01  | bars show correlation between lagged sentiment and same-day return",
             ha="center", fontsize=8, color="#8b949e")
    fig.tight_layout()
    _save_or_show(fig, "05_lag_correlations", save_dir)


# ---------------------------------------------------------------------------
# Q6 — Cross-ticker comparison heatmap
# ---------------------------------------------------------------------------

def plot_cross_ticker_heatmap(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    Heatmap of key statistics per ticker:
      mean sentiment | sentiment std | coverage rate |
      avg return on bullish days | avg return on bearish days
    """
    if "mean_score" not in df.columns:
        print("  [SKIP] No sentiment scores for heatmap.")
        return

    rows = []
    for ticker, g in df.groupby("ticker"):
        scored = g[g["mean_score"].notna() & (g["article_count"] > 0)]
        bullish_days = scored[scored["dominant_label"] == "bullish"]
        bearish_days = scored[scored["dominant_label"] == "bearish"]

        # Next-day return
        g_sorted = g.sort_values("date").copy()
        g_sorted["next_return"] = g_sorted["daily_return"].shift(-1)
        bullish_nret = g_sorted[g_sorted["dominant_label"] == "bullish"]["next_return"].mean()
        bearish_nret = g_sorted[g_sorted["dominant_label"] == "bearish"]["next_return"].mean()

        rows.append({
            "Ticker":              ticker,
            "Avg Sentiment":       round(scored["mean_score"].mean(), 3),
            "Sentiment Std":       round(scored["mean_score"].std(), 3),
            "Coverage Rate":       round((g["article_count"] > 0).mean(), 3),
            "Ret on Bullish Day":  round(bullish_nret * 100, 3) if pd.notna(bullish_nret) else 0,
            "Ret on Bearish Day":  round(bearish_nret * 100, 3) if pd.notna(bearish_nret) else 0,
        })

    stats_df = pd.DataFrame(rows).set_index("Ticker")

    fig, ax = plt.subplots(figsize=(10, 4))
    fig.suptitle("Q6 · Cross-Ticker Sentiment Statistics", y=1.02)

    sns.heatmap(
        stats_df.T,
        annot     = True,
        fmt       = ".3f",
        cmap      = "RdYlGn",
        ax        = ax,
        linewidths= 0.5,
        linecolor = "#30363d",
        cbar_kws  = {"shrink": 0.8},
    )
    ax.set_title("Row = metric  |  Column = ticker")
    ax.tick_params(axis="x", colors="#c9d1d9")
    ax.tick_params(axis="y", colors="#c9d1d9")

    fig.tight_layout()
    _save_or_show(fig, "06_cross_ticker_heatmap", save_dir)


# ---------------------------------------------------------------------------
# Q7 — Sentiment momentum distribution
# ---------------------------------------------------------------------------

def plot_momentum_distribution(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    Histogram of sentiment_momentum (day-over-day sentiment change).
    Answers: how often and how violently does sentiment flip?
    """
    if "sentiment_momentum" not in df.columns:
        print("  [SKIP] No sentiment_momentum column.")
        return

    mom = df[df["sentiment_momentum"].notna()]
    if mom.empty:
        print("  [SKIP] sentiment_momentum is all null.")
        return

    fig, axes = plt.subplots(1, len(df["ticker"].unique()), figsize=(14, 4), sharey=True)
    if len(df["ticker"].unique()) == 1:
        axes = [axes]
    fig.suptitle("Q7 · Sentiment Momentum Distribution", y=1.02)

    for ax, (ticker, g) in zip(axes, mom.groupby("ticker")):
        color = _ticker_color(ticker)
        ax.hist(g["sentiment_momentum"], bins=30, color=color, alpha=0.7, edgecolor="none")
        ax.axvline(0, color="#f0f6fc", linewidth=1, linestyle="--")
        skew = float(g["sentiment_momentum"].skew())
        ax.text(0.05, 0.93, f"skew = {skew:.2f}",
                transform=ax.transAxes, fontsize=9, color="#f0f6fc")
        ax.set_title(ticker, color=color)
        ax.set_xlabel("Sentiment Momentum (Δ score)")
    axes[0].set_ylabel("Count")

    fig.tight_layout()
    _save_or_show(fig, "07_momentum_distribution", save_dir)


# ---------------------------------------------------------------------------
# Q8 — Outlier detection
# ---------------------------------------------------------------------------

def plot_outlier_days(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    Scatter: sentiment score vs. daily return, highlighting extreme days.
    Prints a table of the top-10 outlier dates worth investigating.
    """
    if "mean_score" not in df.columns:
        print("  [SKIP] No sentiment scores.")
        return

    scored = df[df["mean_score"].notna() & df["daily_return"].notna() & (df["article_count"] > 0)].copy()
    if scored.empty:
        return

    # Define outlier = |return| > 2σ or |score| > 0.5
    ret_std    = scored["daily_return"].std()
    scored["is_outlier"] = (
        (scored["daily_return"].abs() > 2 * ret_std) |
        (scored["mean_score"].abs() > 0.5)
    )

    fig, ax = plt.subplots(figsize=(10, 6))
    fig.suptitle("Q8 · Outlier Days: Extreme Sentiment or Return", y=1.02)

    for ticker, g in scored.groupby("ticker"):
        normal  = g[~g["is_outlier"]]
        extreme = g[g["is_outlier"]]
        color   = _ticker_color(ticker)
        ax.scatter(normal["mean_score"],  normal["daily_return"] * 100,
                   alpha=0.3, s=15, color=color, edgecolors="none", label=ticker)
        ax.scatter(extreme["mean_score"], extreme["daily_return"] * 100,
                   alpha=0.9, s=60, color=color, edgecolors="#f0f6fc",
                   linewidths=0.8, marker="D")

    ax.axhline(0, color="#8b949e", linewidth=0.6)
    ax.axvline(0, color="#8b949e", linewidth=0.6)
    ax.set_xlabel("Daily Sentiment Score")
    ax.set_ylabel("Daily Return (%)")
    ax.legend()

    fig.tight_layout()
    _save_or_show(fig, "08_outlier_days", save_dir)

    # Print outlier table
    outliers = scored[scored["is_outlier"]][["ticker", "date", "mean_score", "daily_return", "article_count"]]
    outliers = outliers.sort_values("daily_return", key=abs, ascending=False).head(10)
    outliers["daily_return"] = (outliers["daily_return"] * 100).round(2)
    outliers["mean_score"]   = outliers["mean_score"].round(3)
    print("\nTop-10 Outlier Days:")
    print(outliers.to_string(index=False))


# ---------------------------------------------------------------------------
# Q10 — Rolling 30-day correlation
# ---------------------------------------------------------------------------

def plot_rolling_correlation(df: pd.DataFrame, save_dir: Optional[str] = None):
    """
    Rolling 30-day Pearson r between mean_score and daily_return.
    Answers: is the predictive relationship stable, or does it come and go?
    """
    if "mean_score" not in df.columns:
        print("  [SKIP] No sentiment scores.")
        return

    fig, ax = plt.subplots(figsize=(14, 5))
    fig.suptitle("Q10 · Rolling 30-Day Correlation: Sentiment → Return", y=1.02)

    for ticker, g in df.groupby("ticker"):
        g = g.sort_values("date").set_index("date")
        g = g[g["mean_score"].notna() & g["daily_return"].notna()]
        if len(g) < 35:
            continue
        rolling_corr = g["mean_score"].rolling(30).corr(g["daily_return"])
        ax.plot(rolling_corr.index, rolling_corr.values,
                color=_ticker_color(ticker), linewidth=1.5, label=ticker)

    ax.axhline(0,    color="#f0f6fc", linewidth=0.8, linestyle="--", alpha=0.5)
    ax.axhline(0.2,  color=SENTIMENT_COLORS["bullish"], linewidth=0.5, linestyle=":")
    ax.axhline(-0.2, color=SENTIMENT_COLORS["bearish"], linewidth=0.5, linestyle=":")
    ax.set_ylabel("Pearson r (rolling 30d)")
    ax.set_xlabel("Date")
    ax.legend()
    ax.set_ylim(-1, 1)

    fig.tight_layout()
    _save_or_show(fig, "10_rolling_correlation", save_dir)


# ---------------------------------------------------------------------------
# Summary report printed to console
# ---------------------------------------------------------------------------

def print_summary(df: pd.DataFrame):
    sep = "─" * 60
    print(f"\n{sep}")
    print("  FINSENTIMENT LAB · EDA SUMMARY")
    print(sep)
    print(f"  Date range : {df['date'].min().date()} → {df['date'].max().date()}")
    print(f"  Tickers    : {', '.join(df['ticker'].unique())}")
    print(f"  Total rows : {len(df)}")
    print(sep)

    for ticker, g in df.groupby("ticker"):
        print(f"\n  {ticker}")
        print(f"    Trading days    : {len(g)}")
        print(f"    Days with news  : {(g['article_count'] > 0).sum()}")
        print(f"    Total articles  : {int(g['article_count'].sum())}")

        if "mean_score" in g.columns and g["mean_score"].notna().any():
            scored = g[g["mean_score"].notna()]
            print(f"    Avg sentiment   : {scored['mean_score'].mean():.4f}")
            print(f"    Sentiment std   : {scored['mean_score'].std():.4f}")
            if "dominant_label" in scored.columns:
                vc = scored["dominant_label"].value_counts(normalize=True) * 100
                label_str = "  ".join(f"{k}:{v:.0f}%" for k, v in vc.items())
                print(f"    Labels          : {label_str}")

        if "daily_return" in g.columns and g["daily_return"].notna().any():
            ret = g["daily_return"].dropna()
            print(f"    Avg daily ret   : {ret.mean()*100:.3f}%")
            print(f"    Return vol      : {ret.std()*100:.3f}%")

    print(f"\n{sep}\n")


# ===========================================================================
# Main entry-point
# ===========================================================================

def run_eda(input_path: Optional[str] = None, save_dir: Optional[str] = None):
    """Run the full EDA suite."""
    df = load_data(input_path)
    print_summary(df)

    plots = [
        ("Sentiment Distribution & Label Balance", plot_sentiment_distribution),
        ("News Coverage",                          plot_news_coverage),
        ("Sentiment vs. Next-Day Return",          plot_sentiment_vs_return),
        ("Sentiment + Price Time Series",          plot_sentiment_and_price),
        ("Lag Correlations",                       plot_lag_correlations),
        ("Cross-Ticker Heatmap",                   plot_cross_ticker_heatmap),
        ("Sentiment Momentum Distribution",        plot_momentum_distribution),
        ("Outlier Days",                           plot_outlier_days),
        ("Rolling 30-Day Correlation",             plot_rolling_correlation),
    ]

    print(f"Generating {len(plots)} plots…\n")
    for name, fn in plots:
        print(f"  → {name}")
        try:
            fn(df, save_dir=save_dir)
        except Exception as exc:
            print(f"    [ERROR] {exc}")

    print("\nEDA complete.")
    if save_dir:
        print(f"All plots saved to: {save_dir}")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="FinSentiment Lab — EDA")
    parser.add_argument("--input", default=None,          help="Path to enriched parquet file")
    parser.add_argument("--save",  action="store_true",   help="Save plots to reports/eda/")
    args = parser.parse_args()

    save_dir = os.path.join("reports", "eda") if args.save else None
    run_eda(input_path=args.input, save_dir=save_dir)